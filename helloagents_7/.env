# API密钥
LLM_API_KEY="sk-0c0e4add272a4c6a9fe921450192e38b"

# 服务地址
LLM_BASE_URL=https://api.deepseek.com
# 超时时间（可选，默认60秒）
LLM_TIMEOUT=60

